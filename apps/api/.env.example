# App
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/hotel_os"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Storage (Cloudflare R2 or AWS S3)
S3_BUCKET=hotel-os-uploads
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Email (Resend)
RESEND_API_KEY=

# Payments (Stripe or Paystack)
STRIPE_SECRET_KEY=
PAYSTACK_SECRET_KEY=
