# App
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
PLATFORM_ADMIN_URL=http://localhost:3001
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600
PLATFORM_RATE_LIMIT_WINDOW_MS=60000
PLATFORM_RATE_LIMIT_MAX=60
PLATFORM_AUTH_RATE_LIMIT_WINDOW_MS=60000
PLATFORM_AUTH_RATE_LIMIT_MAX=20

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/hotel_os"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET=""
JWT_REFRESH_EXPIRES_IN="30d"

# Storage (Cloudflare R2 or AWS S3)
S3_BUCKET=hotel-os-uploads
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Email (Resend)
EMAIL_FROM="HotelOS <noreply@example.com>"
RESEND_API_KEY=

# Browser Push (VAPID)
# Generate these once with:
# pnpm web-push generate-vapid-keys
# pnpm --filter @hotel-os/api exec web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
# Use a mailto: address you control, or an https URL for your app/contact page
WEB_PUSH_SUBJECT="mailto:ops@example.com"

# Monitoring / release metadata
# Optional Slack incoming webhook for critical startup, readiness, and unhandled-error alerts.
# In production, set these from the deployment platform for the exact release being rolled out.
# If using the GitHub Actions -> Render rollout, Render receives these values at deploy time.
MONITORING_ALERT_WEBHOOK_URL=
MONITORING_ALERT_DEDUP_MS=300000
DEPLOYMENT_ENVIRONMENT=development
RELEASE_VERSION=
RELEASE_COMMIT_SHA=

# Super admin platform auth
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME="Platform Super Admin"
SUPER_ADMIN_MFA_ISSUER="HotelOS Platform"
SUPER_ADMIN_IMPERSONATION_TTL="30m"

# Protected seed route
# When set, POST /api/v1/seed?key=... will run the Prisma demo seed.
SEED_ROUTE_KEY=

# Payments (Stripe or Paystack)
STRIPE_SECRET_KEY=
PAYSTACK_SECRET_KEY=
