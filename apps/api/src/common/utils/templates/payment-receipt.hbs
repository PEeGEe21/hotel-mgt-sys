<html>
  <head>
    <meta charset='utf-8' />
    <title>Payment Receipt</title>
    <style>
      * {
        box-sizing: border-box;
      }
      body {
        font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
        padding: 24px;
        color: #0f172a;
      }
      .title {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 6px;
      }
      .subtitle {
        color: #64748b;
        font-size: 12px;
        margin-bottom: 16px;
      }
      .block {
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 14px;
        margin-bottom: 14px;
      }
      .row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        font-size: 13px;
        margin-bottom: 8px;
      }
      .label {
        color: #64748b;
      }
      .amount {
        font-size: 20px;
        font-weight: 700;
        color: #0f172a;
      }
      .footer {
        margin-top: 18px;
        font-size: 11px;
        color: #94a3b8;
        text-align: center;
      }
      @media print {
        body {
          padding: 0;
        }
      }
    </style>
  </head>
  <body>
    <div class='title'>Payment Receipt</div>
    <div class='subtitle'>Reservation {{reservationNo}} · Receipt {{receiptId}}</div>
    <div class='block'>
      <div class='row'><span class='label'>Guest</span><span>{{guestName}}</span></div>
      <div class='row'><span class='label'>Room</span><span>{{roomNumber}}</span></div>
      <div class='row'><span class='label'>Stay</span><span>{{stayRange}}</span></div>
    </div>
    <div class='block'>
      <div class='row'><span class='label'>Payment Date</span><span>{{paidAt}}</span></div>
      <div class='row'><span class='label'>Method</span><span>{{paymentMethod}}</span></div>
      {{#if paymentReference}}<div class='row'><span class='label'>Reference</span><span
        >{{paymentReference}}</span></div>{{/if}}
      {{#if paymentNote}}<div class='row'><span class='label'>Notes</span><span>{{paymentNote}}</span></div>{{/if}}
      <div class='row' style='margin-top: 12px;'><span class='label'>Amount</span><span
          class='amount'
        >{{amount}}</span></div>
    </div>
    <div class='row'><span class='label'>Printed</span><span>{{printedAt}}</span></div>
    <div class='footer'>Thank you for your payment.</div>
    <script>
      window.onload = () => { window.print(); window.onafterprint = () => window.close(); };
    </script>
  </body>
</html>
