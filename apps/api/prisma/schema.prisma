generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  RECEPTIONIST
  HOUSEKEEPING
  CASHIER
  COOK
  BARTENDER
  STAFF
}

enum PermissionChangeTarget {
  ROLE
  USER
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  DIRTY
  MAINTENANCE
  OUT_OF_ORDER
  RESERVED
  HOUSEKEEPING
}

enum FacilityStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum RoomType {
  STANDARD
  DELUXE
  SUITE
  EXECUTIVE
  PRESIDENTIAL
  PENTHOUSE
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum AttendanceType {
  CLOCK_IN
  CLOCK_OUT
}

enum HotelCronJobType {
  ATTENDANCE_ABSENCE_SCAN
  CHECKOUT_DUE_SCAN
  UPCOMING_ARRIVAL_SCAN
  OVERDUE_PAYMENT_SCAN
  HOUSEKEEPING_FOLLOW_UP_SCAN
  NO_SHOW_FOLLOW_UP_SCAN
  MAINTENANCE_ESCALATION_SCAN
  DAILY_DIGEST_SCAN
}

enum HotelOnboardingStatus {
  PENDING_SETUP
  ROOMS_ADDED
  STAFF_INVITED
  ACTIVE
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum PrepStation {
  NONE
  KITCHEN
  BAR
}

enum PrepStatus {
  QUEUED
  IN_PROGRESS
  READY
  FULFILLED
  CANCELLED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  SKIPPED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  ANNUAL
  SICK
  EMERGENCY
  UNPAID
  MATERNITY
  PATERNITY
}

enum GuestRole {
  PRIMARY // the person who made the booking
  ADDITIONAL // other adult guests
  CHILD // minors, no ID required
}

enum BookingType {
  INDIVIDUAL // 1 or 2 guests, single room
  FAMILY // adults + children, single room
  COMPANY // billed to a company account
  GROUP // multiple rooms under one booking
}

enum KeycardStatus {
  PENDING
  ACTIVE
  FAILED
  EXPIRED
  REVOKED
  LOST
}

enum KeycardType {
  PHYSICAL
  MOBILE
}

enum KeycardAccessResult {
  GRANTED
  DENIED
  EXPIRED
  REVOKED
  UNKNOWN
}

enum KeycardAccessMethod {
  RFID
  NFC
  BLE
  MANUAL
  VENDOR_SYNC
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  GRACE
  SUSPENDED
  EXPIRED
  CANCELLED
}

enum FeatureScopeType {
  MODULE
  SUB_FEATURE
  LIMIT
}

enum FeatureRolloutStage {
  INTERNAL
  BETA
  GA
  DEPRECATED
}

enum SupportCaseSource {
  HOTEL
  PLATFORM
  SYSTEM
}

enum SupportCasePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SupportCaseStatus {
  OPEN
  TRIAGED
  IN_PROGRESS
  WAITING_ON_HOTEL
  RESOLVED
  CLOSED
}

enum SupportCommentVisibility {
  INTERNAL
  HOTEL_VISIBLE
}

// ─── HOTEL ────────────────────────────────────────────────────────────────────

model Hotel {
  id                                  String   @id @default(uuid())
  name                                String
  domain                              String?  @unique
  address                             String
  city                                String
  state                               String?
  country                             String
  phone                               String
  phoneNormalized                     String?
  email                               String
  website                             String?
  description                         String?
  logo                                String?
  currency                            String   @default("NGN")
  timezone                            String   @default("Africa/Lagos")
  onboardingStatus                    HotelOnboardingStatus @default(PENDING_SETUP)
  keycardAuthEnabled                  Boolean  @default(false)
  lockVendor                          String?
  lockApiKey                          String?
  lockApiConfig                       Json?
  suspendedAt                         DateTime?
  suspensionReason                    String?
  deletedAt                           DateTime?
  purgeAfterAt                        DateTime?
  taxRate                             Decimal? @default(0)
  latitude                            Float?
  longitude                           Float?
  geofenceEnabled                     Boolean  @default(false)
  geofenceRadiusMeters                Int      @default(150)
  attendancePinRequired               Boolean  @default(false)
  attendanceKioskEnabled              Boolean  @default(true)
  attendancePersonalEnabled           Boolean  @default(true)
  attendanceAutoClockOutEnabled       Boolean  @default(true)
  attendanceAutoClockOutHour          Int      @default(0)
  attendanceAutoClockOutMinute        Int      @default(0)
  defaultCheckoutHour                 Int      @default(12)
  defaultCheckoutMinute               Int      @default(0)
  guestCheckoutReminderEnabled        Boolean  @default(false)
  guestCheckoutReminderLeadDays       Int[]    @default([1, 0])
  emailAutoRetryEnabled               Boolean  @default(false)
  autoCreateCheckoutHousekeepingTasks Boolean  @default(true)
  housekeepingFollowUpEnabled         Boolean  @default(false)
  housekeepingFollowUpGraceHours      Int      @default(2)
  contractExpiryWarningDays           Int      @default(60)
  invoiceTemplateSettings             Json?
  hrContractSettings                  Json?
  createdAt                           DateTime @default(now())
  updatedAt                           DateTime @updatedAt

  floors                  Floor[]
  rooms                   Room[]
  staff                   Staff[]
  guests                  Guest[]
  reservations            Reservation[]
  facilities              Facility[]
  facilityBookings        FacilityBooking[]
  facilityRequisitions    FacilityRequisition[]
  maintenanceRequests     MaintenanceRequest[]
  facilityComplaints      FacilityComplaint[]
  facilityInspections     FacilityInspection[]
  facilityTypes           FacilityType[]
  facilityLocations       FacilityLocation[]
  facilityDepartments     FacilityDepartment[]
  posOrders               PosOrder[]
  posProducts             PosProduct[]
  posTerminals            PosTerminal[]
  posTerminalGroups       PosTerminalGroup[]
  posTables               PosTable[]
  inventoryItems          InventoryItem[]
  housekeepingTasks       HousekeepingTask[]
  companies               Company[]
  groupBookings           GroupBooking[]
  departments             Department[]
  jobTitles               JobTitle[]
  inventoryCategories     InventoryCategory[]
  posProductCategories    PosProductCategory[]
  suppliers               Supplier[]
  shiftTemplates          ShiftTemplate[]
  staffShiftOverrides     StaffShiftOverride[]
  roomTypeConfigs         RoomTypeConfig[]
  hrContracts             HrContract[]
  hrContractDocuments     HrContractDocument[]
  hrContractApprovalRoutes HrContractApprovalRoute[]
  hrContractApprovals     HrContractApproval[]
  hrContractAuditLogs     HrContractAuditLog[]
  compensationHistory     StaffCompensationHistory[]
  invoices                Invoice[]
  payments                Payment[]
  rolePermissions         RolePermission[]
  permissionAuditLogs     PermissionAuditLog[]
  accounts                Account[]
  journalEntries          JournalEntry[]
  auditLogs               AuditLog[]
  notificationPreferences NotificationPreference[]
  notifications           Notification[]
  emailDeliveryLogs       EmailDeliveryLog[]
  pushSubscriptions       PushSubscription[]
  pushDeliveryLogs        PushDeliveryLog[]
  cronSettings            HotelCronSetting[]
  roleDashboardConfigs    RoleDashboardConfig[]
  realtimeModuleHealth    RealtimeModuleHealth[]
  realtimeEventLogs       RealtimeEventLog[]
  keycards                Keycard[]
  keycardAccessLogs       KeycardAccessLog[]
  subscriptions           HotelSubscription[]
  featureOverrides        HotelFeatureOverride[]
  supportCases            SupportCase[]
  bannerDismissals        HotelBannerDismissal[]
}

model HotelBannerDismissal {
  id                String   @id @default(uuid())
  hotelId           String
  key               String
  contextHash       String
  dismissedUntil    DateTime
  dismissedByUserId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, key])
  @@index([hotelId, dismissedUntil])
}

model DashboardWidget {
  id             String   @id
  title          String
  permissionKey  String
  featureFlag    String?
  defaultEnabled Boolean  @default(true)
  defaultSize    String   @default("compact")
  allowedSizes   String[] @default(["compact", "wide", "full"])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  roleConfigs RoleDashboardConfig[]

  @@index([permissionKey])
  @@index([featureFlag])
}

model RoleDashboardConfig {
  id           String   @id @default(uuid())
  hotelId      String
  role         Role
  widgetId     String
  position     Int
  enabled      Boolean  @default(true)
  sizeOverride String?
  config       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hotel  Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  widget DashboardWidget @relation(fields: [widgetId], references: [id], onDelete: Cascade)

  @@unique([hotelId, role, widgetId])
  @@index([hotelId, role, position])
  @@index([widgetId])
}

model FeatureFlag {
  key          String   @id
  name         String?
  enabled      Boolean  @default(true)
  defaultEnabled Boolean @default(true)
  planRequired String?
  description  String?
  category     String?
  scopeType    FeatureScopeType @default(MODULE)
  rolloutStage FeatureRolloutStage @default(GA)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  planEntitlements PlanFeatureEntitlement[]
  hotelOverrides   HotelFeatureOverride[]
}

model HotelCronSetting {
  id              String           @id @default(uuid())
  hotelId         String
  jobType         HotelCronJobType
  enabled         Boolean          @default(true)
  runAtHour       Int              @default(9)
  runAtMinute     Int              @default(15)
  lastTriggeredAt DateTime?
  lastSucceededAt DateTime?
  lastFailedAt    DateTime?
  lastError       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, jobType])
  @@index([jobType, enabled])
  @@index([hotelId])
}

model RealtimeModuleHealth {
  id             String   @id @default(uuid())
  hotelId        String
  moduleKey      String
  eventName      String
  lastEventAt    DateTime
  lastEventType  String?
  lastSummary    String?
  eventCount     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, moduleKey])
  @@index([hotelId, lastEventAt])
  @@index([moduleKey])
}

model RealtimeEventLog {
  id         String   @id @default(uuid())
  hotelId    String
  moduleKey  String
  eventName  String
  eventType  String
  summary    String
  payload    Json?
  createdAt  DateTime @default(now())

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, createdAt])
  @@index([hotelId, moduleKey, createdAt])
}

// ─── USERS & AUTH ─────────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  username           String?
  passwordHash       String
  role               Role      @default(STAFF)
  isActive           Boolean   @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  mustChangePassword Boolean   @default(false)
  mfaEnabled         Boolean   @default(false)
  mfaSecret          String?
  mfaSetupAt         DateTime?

  // Granular permission overrides on top of role defaults
  permissionGrants String[] @default([])
  permissionDenies String[] @default([])

  staff                   Staff?
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  permissionAuditActor    PermissionAuditLog[]     @relation("PermissionAuditActor")
  permissionAuditTarget   PermissionAuditLog[]     @relation("PermissionAuditTarget")
  auditLogsActor          AuditLog[]               @relation("AuditActor")
  auditLogsTarget         AuditLog[]               @relation("AuditTarget")
  notificationPreferences NotificationPreference[]
  notifications           Notification[]
  pushSubscriptions       PushSubscription[]
  pushDeliveryLogs        PushDeliveryLog[]
  supportCasesCreated     SupportCase[]        @relation("SupportCaseCreatedBy")
  supportCasesAssigned    SupportCase[]        @relation("SupportCaseAssignedAdmin")
  supportCaseEvents       SupportCaseEvent[]
  supportCaseComments     SupportCaseComment[]
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RefreshToken {
  id              String   @id @default(uuid())
  token           String   @unique
  userId          String
  impersonatorId  String?
  isImpersonation Boolean  @default(false)
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id           String   @id @default(uuid())
  hotelId      String?
  actorUserId  String
  action       String
  targetType   String?
  targetId     String?
  targetUserId String?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  hotel      Hotel? @relation(fields: [hotelId], references: [id])
  actor      User  @relation("AuditActor", fields: [actorUserId], references: [id])
  targetUser User? @relation("AuditTarget", fields: [targetUserId], references: [id])

  @@index([hotelId])
  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action])
}

model NotificationPreference {
  id           String   @id @default(uuid())
  userId       String
  hotelId      String
  event        String
  channelEmail Boolean  @default(true)
  channelInApp Boolean  @default(true)
  channelPush  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([userId, event])
  @@index([hotelId])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  hotelId   String
  event     String
  title     String
  message   String
  metadata  Json?
  readAt    DateTime?
  pinnedAt  DateTime?
  archivedAt DateTime?
  createdAt DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, createdAt])
  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([userId, pinnedAt])
  @@index([userId, archivedAt])
}

model EmailDeliveryLog {
  id                String    @id @default(uuid())
  hotelId           String?
  recipient         String
  subject           String
  fromEmail         String
  provider          String
  event             String?
  status            String
  errorMessage      String?
  providerMessageId String?
  metadata          Json?
  sentAt            DateTime?
  createdAt         DateTime  @default(now())

  hotel Hotel? @relation(fields: [hotelId], references: [id], onDelete: SetNull)

  @@index([hotelId, createdAt])
  @@index([status, createdAt])
  @@index([event, createdAt])
  @@index([recipient, createdAt])
}

model PushSubscription {
  id                  String            @id @default(uuid())
  userId              String
  hotelId             String?
  endpoint            String            @unique
  p256dh              String
  auth                String
  userAgent           String?
  lastAttemptAt       DateTime?
  lastSuccessAt       DateTime?
  lastFailureAt       DateTime?
  lastFailureReason   String?
  lastFailureStatusCode Int?
  lastDeliveredEvent  String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel            Hotel?            @relation(fields: [hotelId], references: [id], onDelete: SetNull)
  pushDeliveryLogs PushDeliveryLog[]

  @@index([userId])
  @@index([hotelId])
}

model PushDeliveryLog {
  id                    String             @id @default(uuid())
  pushSubscriptionId    String?
  userId                String
  hotelId               String?
  event                 String
  title                 String
  status                String
  failureReason         String?
  failureStatusCode     Int?
  endpoint              String
  correlationId         String?
  isTest                Boolean            @default(false)
  metadata              Json?
  deliveredAt           DateTime?
  createdAt             DateTime           @default(now())

  pushSubscription PushSubscription? @relation(fields: [pushSubscriptionId], references: [id], onDelete: SetNull)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel            Hotel?            @relation(fields: [hotelId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([hotelId, createdAt])
  @@index([status, createdAt])
  @@index([pushSubscriptionId])
}

model RolePermission {
  id          String   @id @default(uuid())
  hotelId     String
  role        Role
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@unique([hotelId, role])
  @@index([hotelId])
}

model PermissionAuditLog {
  id           String                 @id @default(uuid())
  hotelId      String
  actorUserId  String
  targetUserId String?
  targetRole   Role?
  targetType   PermissionChangeTarget
  before       String[]               @default([])
  after        String[]               @default([])
  reason       String?
  createdAt    DateTime               @default(now())

  hotel      Hotel @relation(fields: [hotelId], references: [id])
  actor      User  @relation("PermissionAuditActor", fields: [actorUserId], references: [id])
  targetUser User? @relation("PermissionAuditTarget", fields: [targetUserId], references: [id])

  @@index([hotelId])
  @@index([actorUserId])
  @@index([targetUserId])
}

// ─── STAFF ────────────────────────────────────────────────────────────────────

model Staff {
  id                String    @id @default(uuid())
  userId            String    @unique
  hotelId           String
  jobTitleId        String?
  shiftTemplateId   String?
  employeeCode      String    @unique
  firstName         String
  lastName          String
  phone             String?
  phoneNormalized   String?
  avatar            String?
  department        String
  position          String
  salary            Decimal   @default(0)
  hireDate          DateTime
  pinHash           String?
  pinUpdatedAt      DateTime?
  pinLastUsedAt     DateTime?
  pinFailedAttempts Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user                          User                  @relation(fields: [userId], references: [id])
  hotel                         Hotel                 @relation(fields: [hotelId], references: [id])
  jobTitle                      JobTitle?             @relation(fields: [jobTitleId], references: [id])
  defaultShift                  ShiftTemplate?        @relation(fields: [shiftTemplateId], references: [id])
  operatingTerminals            PosTerminal[]         @relation("CurrentTerminalStaff")
  attendance                    Attendance[]
  leaves                        Leave[]
  tasks                         HousekeepingTask[]
  posTerminals                  PosTerminal[]
  posOrders                     PosOrder[]
  facilityBookingsCreated       FacilityBooking[]     @relation("FacilityBookingCreatedBy")
  facilityBookingsApproved      FacilityBooking[]     @relation("FacilityBookingApprovedBy")
  facilityDepartmentsHeaded     FacilityDepartment[]  @relation("FacilityDepartmentHead")
  facilitiesManaged             Facility[]            @relation("FacilityManager")
  facilityRequisitionsRequested FacilityRequisition[] @relation("FacilityRequisitionRequestedBy")
  facilityRequisitionsApproved  FacilityRequisition[] @relation("FacilityRequisitionApprovedBy")
  maintenanceRequestsReported   MaintenanceRequest[]  @relation("MaintenanceRequestReportedBy")
  maintenanceRequestsAssigned   MaintenanceRequest[]  @relation("MaintenanceRequestAssignedTo")
  facilityComplaintsReported    FacilityComplaint[]   @relation("FacilityComplaintReportedBy")
  facilityInspectionsScheduled  FacilityInspection[]  @relation("FacilityInspectionScheduledBy")
  hrContracts                   HrContract[]
  compensationHistory           StaffCompensationHistory[]
  shiftOverrides               StaffShiftOverride[]

  @@index([hotelId, jobTitleId])
  @@index([hotelId, shiftTemplateId])
}

model Attendance {
  id        String         @id @default(uuid())
  staffId   String
  hotelId   String
  type      AttendanceType
  timestamp DateTime       @default(now())
  method    String         @default("PIN") // PIN, QR, BIOMETRIC
  note      String?
  latitude  Float?
  longitude Float?

  staff Staff @relation(fields: [staffId], references: [id])

  @@index([hotelId])
  @@index([staffId, timestamp])
}

model Leave {
  id        String      @id @default(uuid())
  staffId   String
  hotelId   String
  type      LeaveType
  startDate DateTime
  endDate   DateTime
  reason    String
  status    LeaveStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  staff Staff @relation(fields: [staffId], references: [id])

  @@index([hotelId])
}

// ─── DEPARTMENTS ─────────────────────────────────────────────────────────────

model Department {
  id          String   @id @default(uuid())
  hotelId     String
  name        String
  description String?
  color       String   @default("bg-blue-500")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id])
  hrContracts HrContract[]
  jobTitles JobTitle[]

  @@unique([hotelId, name])
  @@index([hotelId])
}

model JobTitle {
  id          String   @id @default(uuid())
  hotelId     String
  departmentId String?
  name        String
  description String?
  color       String   @default("bg-cyan-500")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel       Hotel       @relation(fields: [hotelId], references: [id])
  department  Department? @relation(fields: [departmentId], references: [id])
  staff       Staff[]

  @@unique([hotelId, name])
  @@index([hotelId])
  @@index([hotelId, departmentId])
}

// ─── HR CONTRACTS ────────────────────────────────────────────────────────────

model HrContract {
  id                    String   @id @default(uuid())
  hotelId               String
  staffId               String
  departmentId          String?
  positionTitle         String
  staffNameSnapshot     String
  employeeCodeSnapshot  String
  departmentSnapshot    String
  positionSnapshot      String
  contractNo            String   @unique
  type                  String
  status                String   @default("DRAFT")
  startDate             DateTime
  endDate               DateTime?
  salary                Decimal
  currency              String   @default("NGN")
  probationEndDate      DateTime?
  reportingManagerStaffId String?
  notes                 String?
  renewedFromContractId String?
  submittedAt           DateTime?
  submittedByUserId     String?
  approvedAt            DateTime?
  approvedByUserId      String?
  approvalComment       String?
  signedAt              DateTime?
  signedByUserId        String?
  activatedAt           DateTime?
  rejectedAt            DateTime?
  rejectedByUserId      String?
  rejectionReason       String?
  terminationDate       DateTime?
  terminationReason     String?
  terminatedByUserId    String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  hotel                 Hotel                    @relation(fields: [hotelId], references: [id])
  staff                 Staff                    @relation(fields: [staffId], references: [id])
  department            Department?              @relation(fields: [departmentId], references: [id])
  renewedFromContract   HrContract?              @relation("HrContractRenewalChain", fields: [renewedFromContractId], references: [id])
  renewedContracts      HrContract[]             @relation("HrContractRenewalChain")
  compensationHistory   StaffCompensationHistory[]
  documents             HrContractDocument[]
  approvals             HrContractApproval[]
  auditLogs             HrContractAuditLog[]

  @@index([hotelId])
  @@index([hotelId, staffId])
  @@index([hotelId, departmentId])
  @@index([hotelId, status])
  @@index([hotelId, type])
  @@index([hotelId, endDate])
  @@index([hotelId, terminationDate])
  @@index([renewedFromContractId])
  @@index([hotelId, submittedAt])
  @@index([hotelId, approvedAt])
  @@index([hotelId, signedAt])
}

model HrContractApprovalRoute {
  id          String   @id @default(uuid())
  hotelId     String?
  contractType String?
  isDefault   Boolean  @default(false)
  name        String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel       Hotel?                      @relation(fields: [hotelId], references: [id])
  steps       HrContractApprovalRouteStep[]

  @@index([hotelId, isDefault, isActive])
  @@index([hotelId, contractType, isActive])
}

model HrContractApprovalRouteStep {
  id        String   @id @default(uuid())
  routeId    String
  stepOrder Int
  role      String
  required  Boolean  @default(true)
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  route     HrContractApprovalRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([routeId, stepOrder])
  @@index([routeId])
}

model HrContractApproval {
  id            String   @id @default(uuid())
  hotelId       String
  contractId    String
  routeName     String?
  stepOrder     Int
  role          String
  required      Boolean  @default(true)
  assignedUserId String?
  status        String   @default("PENDING")
  comment       String?
  actedAt       DateTime?
  actedByUserId String?
  createdAt     DateTime @default(now())

  hotel         Hotel      @relation(fields: [hotelId], references: [id])
  contract      HrContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([hotelId, contractId, stepOrder])
  @@index([contractId])
}

model HrContractAuditLog {
  id           String   @id @default(uuid())
  hotelId      String
  contractId   String
  actorUserId  String?
  action       String
  fromStatus   String?
  toStatus     String?
  metadata     Json?
  createdAt    DateTime @default(now())

  hotel        Hotel      @relation(fields: [hotelId], references: [id])
  contract     HrContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([hotelId, contractId, createdAt])
  @@index([contractId])
}

model StaffCompensationHistory {
  id             String   @id @default(uuid())
  hotelId        String
  staffId        String
  contractId     String?
  amount         Decimal
  currency       String   @default("NGN")
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  reason         String?
  createdByUserId String?
  createdAt      DateTime @default(now())

  hotel          Hotel      @relation(fields: [hotelId], references: [id])
  staff          Staff      @relation(fields: [staffId], references: [id])
  contract       HrContract? @relation(fields: [contractId], references: [id])

  @@index([hotelId])
  @@index([hotelId, staffId, effectiveFrom])
  @@index([contractId])
}

model HrContractDocument {
  id              String   @id @default(uuid())
  hotelId         String
  contractId      String
  documentType    String
  source          String   @default("UPLOADED")
  fileName        String
  storageKey      String?
  fileUrl         String
  mimeType        String?
  fileSizeBytes   Int?
  uploadedByUserId String?
  uploadedAt      DateTime @default(now())

  hotel           Hotel      @relation(fields: [hotelId], references: [id])
  contract        HrContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([contractId])
  @@index([hotelId, contractId, uploadedAt])
}

// ─── INVENTORY CATEGORIES ────────────────────────────────────────────────────

model InventoryCategory {
  id          String   @id @default(uuid())
  hotelId     String
  name        String
  description String?
  color       String   @default("bg-blue-500")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@unique([hotelId, name])
  @@index([hotelId])
}

// ─── SUPPLIERS ──────────────────────────────────────────────────────────────

model Supplier {
  id         String   @id @default(uuid())
  hotelId    String
  name       String
  contact    String?
  phone      String?
  email      String?
  address    String?
  notes      String?
  categories String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@unique([hotelId, name])
  @@index([hotelId])
}

// ─── SHIFT TEMPLATES ────────────────────────────────────────────────────────

model ShiftTemplate {
  id        String   @id @default(uuid())
  hotelId   String
  name      String
  startTime String
  endTime   String
  days      String[] @default([])
  color     String   @default("bg-blue-500")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel        Hotel   @relation(fields: [hotelId], references: [id])
  defaultStaff Staff[]
  overrides    StaffShiftOverride[]

  @@unique([hotelId, name])
  @@index([hotelId])
}

model StaffShiftOverride {
  id              String   @id @default(uuid())
  hotelId         String
  staffId         String
  shiftTemplateId String
  isActive        Boolean  @default(true)
  dateFrom        DateTime
  dateTo          DateTime
  reason          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  hotel         Hotel         @relation(fields: [hotelId], references: [id])
  staff         Staff         @relation(fields: [staffId], references: [id])
  shiftTemplate ShiftTemplate @relation(fields: [shiftTemplateId], references: [id])

  @@index([hotelId, staffId, dateFrom, dateTo])
  @@index([hotelId, shiftTemplateId])
}

// ─── ROOM TYPE CONFIGS ──────────────────────────────────────────────────────

model RoomTypeConfig {
  id          String   @id @default(uuid())
  hotelId     String
  name        String
  description String?
  baseRate    Decimal  @default(0)
  capacity    Int      @default(1)
  beds        String   @default("1 Queen")
  amenities   String[] @default([])
  color       String   @default("bg-blue-500")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@unique([hotelId, name])
  @@index([hotelId])
}

// ─── FLOORS ───────────────────────────────────────────────────────────────────

model Floor {
  id          String   @id @default(uuid())
  hotelId     String
  name        String // "Ground Floor", "Outside Block A", "Rooftop", "Basement"
  level       Int // sort order — negative for basements (e.g. -1)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel Hotel  @relation(fields: [hotelId], references: [id])
  rooms Room[]

  @@unique([hotelId, name])
  @@unique([hotelId, level])
  @@index([hotelId])
}

// ─── ROOMS ────────────────────────────────────────────────────────────────────

model Room {
  id          String     @id @default(uuid())
  hotelId     String
  number      String
  floorId     String?
  type        RoomType
  status      RoomStatus @default(AVAILABLE)
  baseRate    Decimal
  maxGuests   Int        @default(2)
  description String?
  amenities   String[]
  images      String[]
  lockDeviceId String?
  lockVendor   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  hotel               Hotel                @relation(fields: [hotelId], references: [id])
  floor               Floor?               @relation(fields: [floorId], references: [id])
  reservations        Reservation[]
  housekeepingTasks   HousekeepingTask[]
  maintenanceRequests MaintenanceRequest[]
  facilityComplaints  FacilityComplaint[]
  keycards            Keycard[]
  keycardAccessLogs   KeycardAccessLog[]

  @@unique([hotelId, number])
  @@index([hotelId, status])
  @@index([hotelId, floorId])
}

// ─── COMPANIES ────────────────────────────────────────────────────────────────

model Company {
  id              String   @id @default(uuid())
  hotelId         String
  name            String
  email           String?
  phone           String?
  phoneNormalized String?
  address         String?
  taxId           String? // for invoicing
  contactName     String? // primary billing contact
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  hotel        Hotel         @relation(fields: [hotelId], references: [id])
  reservations Reservation[]

  @@unique([hotelId, name])
  @@index([hotelId])
}

// ─── GROUP BOOKINGS ───────────────────────────────────────────────────────────

model GroupBooking {
  id        String   @id @default(uuid())
  hotelId   String
  groupNo   String   @unique // GRP-2026-001
  name      String // "Dangote Wedding Party", "NNPC Conference"
  companyId String? // optional — who is paying
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel        Hotel         @relation(fields: [hotelId], references: [id])
  reservations Reservation[]

  @@index([hotelId])
}

// ─── GUESTS ───────────────────────────────────────────────────────────────────

model Guest {
  id              String  @id @default(uuid())
  hotelId         String
  firstName       String
  lastName        String
  email           String?
  phone           String
  phoneNormalized String?

  nationality String?
  idType      String? // PASSPORT, NATIONAL_ID, DRIVERS_LICENSE
  idNumber    String?
  dateOfBirth DateTime?
  address     String?
  notes       String?
  stayType    String? // FULL_TIME, SHORT_TIME
  isVip       Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  hotel              Hotel               @relation(fields: [hotelId], references: [id])
  reservations       Reservation[] // reservations where this guest is primary
  reservationGuests  ReservationGuest[] // all reservations this guest appears on
  facilityBookings   FacilityBooking[]
  facilityComplaints FacilityComplaint[]
  keycards           Keycard[]

  @@index([hotelId])
  @@index([hotelId, email])
}

// ─── RESERVATIONS ─────────────────────────────────────────────────────────────

model Reservation {
  id              String            @id @default(uuid())
  hotelId         String
  guestId         String // primary guest — quick FK for display
  roomId          String
  companyId       String? // set if this is a company booking
  groupBookingId  String? // set if part of a group
  reservationNo   String            @unique
  bookingType     BookingType       @default(INDIVIDUAL)
  checkIn         DateTime
  checkOut        DateTime
  adults          Int               @default(1)
  children        Int               @default(0)
  status          ReservationStatus @default(PENDING)
  paymentStatus   PaymentStatus     @default(UNPAID)
  totalAmount     Decimal
  paidAmount      Decimal           @default(0)
  source          String            @default("DIRECT")
  specialRequests String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  hotel            Hotel              @relation(fields: [hotelId], references: [id])
  guest            Guest              @relation(fields: [guestId], references: [id])
  room             Room               @relation(fields: [roomId], references: [id])
  company          Company?           @relation(fields: [companyId], references: [id])
  groupBooking     GroupBooking?      @relation(fields: [groupBookingId], references: [id])
  guests           ReservationGuest[] // full guest list including primary
  invoices         Invoice[]
  facilityBookings FacilityBooking[]
  folioItems       FolioItem[]
  posOrders        PosOrder[]
  keycards         Keycard[]

  @@index([hotelId, status])
  @@index([hotelId, checkIn, checkOut])
  @@index([hotelId, companyId])
  @@index([hotelId, groupBookingId])
}

// ─── RESERVATION GUESTS (many guests per reservation) ─────────────────────────

model ReservationGuest {
  id            String    @id @default(uuid())
  reservationId String
  guestId       String
  role          GuestRole @default(ADDITIONAL)
  addedAt       DateTime  @default(now()) // audit — when was this guest added/changed

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  guest       Guest       @relation(fields: [guestId], references: [id])

  @@unique([reservationId, guestId]) // a guest can only appear once per reservation
  @@index([reservationId])
  @@index([guestId])
}

model Keycard {
  id              String         @id @default(uuid())
  hotelId         String
  reservationId   String
  roomId          String
  guestId         String?
  cardUid         String?
  accessToken     String         @unique
  type            KeycardType    @default(PHYSICAL)
  status          KeycardStatus  @default(ACTIVE)
  issuedAt        DateTime       @default(now())
  validFrom       DateTime
  validUntil      DateTime
  revokedAt       DateTime?
  revokedReason   String?
  issuedByStaffId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  hotel      Hotel               @relation(fields: [hotelId], references: [id])
  reservation Reservation        @relation(fields: [reservationId], references: [id])
  room       Room                @relation(fields: [roomId], references: [id])
  guest      Guest?              @relation(fields: [guestId], references: [id])
  accessLogs KeycardAccessLog[]

  @@index([hotelId])
  @@index([reservationId])
  @@index([roomId])
  @@index([guestId])
  @@index([status, validUntil])
}

model KeycardAccessLog {
  id            String              @id @default(uuid())
  hotelId       String?
  keycardId     String?
  roomId        String?
  accessToken   String
  result        KeycardAccessResult
  reason        String?
  method        KeycardAccessMethod
  deviceId      String?
  vendorEventId String?
  ipAddress     String?
  createdAt     DateTime            @default(now())

  hotel   Hotel?   @relation(fields: [hotelId], references: [id])
  keycard Keycard? @relation(fields: [keycardId], references: [id])
  room    Room?    @relation(fields: [roomId], references: [id])

  @@index([hotelId, createdAt])
  @@index([keycardId])
  @@index([roomId, createdAt])
  @@index([accessToken])
}

model SubscriptionPlan {
  id                     String   @id @default(uuid())
  code                   String   @unique
  name                   String
  description            String?
  priceMonthly           Decimal?
  priceYearly            Decimal?
  billingIntervalOptions String[] @default(["MONTHLY", "YEARLY"])
  isActive               Boolean  @default(true)
  isPublic               Boolean  @default(false)
  sortOrder              Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  hotelSubscriptions HotelSubscription[]
  entitlements      PlanFeatureEntitlement[]

  @@index([isActive, sortOrder])
}

model HotelSubscription {
  id                 String             @id @default(uuid())
  hotelId            String
  planId             String?
  status             SubscriptionStatus @default(TRIAL)
  startsAt           DateTime?
  endsAt             DateTime?
  trialEndsAt        DateTime?
  graceEndsAt        DateTime?
  billingEmail       String?
  billingContactName String?
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  hotel Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  plan  SubscriptionPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([hotelId, updatedAt])
  @@index([status])
  @@index([planId])
}

model PlanFeatureEntitlement {
  id         String   @id @default(uuid())
  planId      String
  flagKey     String
  enabled     Boolean @default(true)
  limitValue  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  flag FeatureFlag      @relation(fields: [flagKey], references: [key], onDelete: Cascade)

  @@unique([planId, flagKey])
  @@index([flagKey])
}

model HotelFeatureOverride {
  id         String   @id @default(uuid())
  hotelId    String
  flagKey    String
  enabled    Boolean
  limitValue String?
  reason     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  hotel Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  flag  FeatureFlag @relation(fields: [flagKey], references: [key], onDelete: Cascade)

  @@unique([hotelId, flagKey])
  @@index([flagKey])
}

model SupportCase {
  id                   String             @id @default(uuid())
  hotelId              String
  createdByUserId      String?
  source               SupportCaseSource  @default(HOTEL)
  category             String
  priority             SupportCasePriority @default(MEDIUM)
  status               SupportCaseStatus  @default(OPEN)
  subject              String
  description          String
  requestType          String?
  requestPayload       Json?
  assignedAdminId      String?
  subscriptionSnapshot Json?
  entitlementSnapshot  Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  hotel          Hotel                @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  createdByUser  User?                @relation("SupportCaseCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  assignedAdmin  User?                @relation("SupportCaseAssignedAdmin", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  events         SupportCaseEvent[]
  comments       SupportCaseComment[]

  @@index([hotelId, createdAt])
  @@index([status, priority])
  @@index([assignedAdminId, status])
  @@index([requestType])
}

model SupportCaseEvent {
  id          String   @id @default(uuid())
  caseId       String
  actorUserId  String?
  type         String
  payload      Json?
  createdAt    DateTime @default(now())

  supportCase SupportCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  actorUser   User?       @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([caseId, createdAt])
}

model SupportCaseComment {
  id            String                  @id @default(uuid())
  caseId         String
  authorUserId   String?
  visibility     SupportCommentVisibility @default(INTERNAL)
  body           String
  createdAt      DateTime                @default(now())

  supportCase SupportCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  authorUser  User?       @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([caseId, createdAt])
}

// ─── FINANCE ──────────────────────────────────────────────────────────────────

model Invoice {
  id                String        @id @default(uuid())
  hotelId           String
  reservationId     String? // null for walk-in / POS-only invoices
  posOrderId        String?
  facilityBookingId String?       @unique
  invoiceNo         String        @unique
  issuedAt          DateTime      @default(now())
  dueAt             DateTime?
  subtotal          Decimal
  tax               Decimal
  discount          Decimal       @default(0)
  total             Decimal
  type              String        @default("RESERVATION") // RESERVATION | POS | FACILITY | MANUAL
  paymentStatus     PaymentStatus @default(UNPAID)
  counterpartyName  String?
  notes             String?

  hotel           Hotel            @relation(fields: [hotelId], references: [id])
  reservation     Reservation?     @relation(fields: [reservationId], references: [id])
  posOrder        PosOrder?        @relation(fields: [posOrderId], references: [id])
  facilityBooking FacilityBooking? @relation("FacilityBookingInvoice", fields: [facilityBookingId], references: [id])
  facilityRequisition FacilityRequisition? @relation("FacilityRequisitionInvoice")
  payments        Payment[]

  @@index([hotelId])
  @@index([hotelId, paymentStatus])
  @@index([hotelId, facilityBookingId])
}

model Payment {
  id        String   @id @default(uuid())
  hotelId   String
  invoiceId String
  amount    Decimal
  method    String // CASH, CARD, BANK_TRANSFER, MOBILE_MONEY, ROOM_CHARGE
  reference String?
  paidAt    DateTime @default(now())
  note      String?

  hotel   Hotel   @relation(fields: [hotelId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([hotelId])
}

model FolioItem {
  id                String   @id @default(uuid())
  hotelId           String
  reservationId     String
  facilityBookingId String?
  description       String
  amount            Decimal
  quantity          Int      @default(1)
  category          String // ROOM, FOOD, LAUNDRY, SPA, MISC
  posOrderId        String? // which POS order generated this charge
  createdAt         DateTime @default(now())

  reservation     Reservation      @relation(fields: [reservationId], references: [id])
  facilityBooking FacilityBooking? @relation(fields: [facilityBookingId], references: [id])

  @@index([hotelId])
  @@index([hotelId, facilityBookingId])
}

// ─── POS / STORE ──────────────────────────────────────────────────────────────

model PosOrder {
  id            String      @id @default(uuid())
  hotelId       String
  orderNo       String      @unique
  tableId       String? // FK to PosTable
  tableNo       String?
  roomNo        String?
  reservationId String? // FK for room charge flow
  staffId       String?
  posTerminalId String?
  type          String // DINE_IN, ROOM_SERVICE, TAKEAWAY, RETAIL
  status        OrderStatus @default(PENDING)
  subtotal      Decimal
  tax           Decimal
  discount      Decimal     @default(0)
  total         Decimal
  paymentMethod String?
  isPaid        Boolean     @default(false)
  note          String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  hotel       Hotel        @relation(fields: [hotelId], references: [id])
  posTerminal PosTerminal? @relation(fields: [posTerminalId], references: [id])
  table       PosTable?    @relation(fields: [tableId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])
  staff       Staff?       @relation(fields: [staffId], references: [id])

  items    PosOrderItem[]
  invoices Invoice[]

  @@index([hotelId])
  @@index([hotelId, createdAt])
}

model ProductIngredient {
  id              String   @id @default(uuid())
  hotelId         String
  productId       String
  inventoryItemId String
  quantity        Decimal // amount of inventory item consumed per 1 unit sold
  unit            String? // display unit override (e.g. "ml", "g")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product       PosProduct    @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@unique([productId, inventoryItemId])
  @@index([hotelId])
  @@index([productId])
}

model PosOrderItem {
  id              String      @id @default(uuid())
  orderId         String
  productId       String
  name            String      // snapshot at time of sale
  price           Decimal     // snapshot at time of sale
  quantity        Int
  total           Decimal
  note            String?
  prepStation     PrepStation @default(NONE)
  prepStatus      PrepStatus  @default(QUEUED)
  prepStartedAt   DateTime?
  prepCompletedAt DateTime?
  bumpedAt        DateTime?
  bumpedByStaffId String?

  order   PosOrder   @relation(fields: [orderId], references: [id])
  product PosProduct @relation(fields: [productId], references: [id])

  @@index([orderId, prepStation])
  @@index([prepStation, prepStatus])
}

model PosProduct {
  id          String   @id @default(uuid())
  hotelId     String
  name        String
  sku         String?
  description String?
  price       Decimal
  categoryId  String
  unit        String   @default("item")
  image       String?
  type        String   @default("PHYSICAL") // PHYSICAL | SERVICE | BUNDLE
  prepStation PrepStation @default(NONE)
  isAvailable Boolean  @default(true)
  stock       Int? // null = unlimited (e.g. services)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel       Hotel               @relation(fields: [hotelId], references: [id])
  orderItems  PosOrderItem[]
  ingredients ProductIngredient[]
  category    PosProductCategory  @relation(fields: [categoryId], references: [id])

  @@unique([hotelId, sku])
  @@index([hotelId])
  @@index([hotelId, prepStation])
}

model PosProductCategory {
  id          String   @id @default(uuid())
  hotelId     String
  name        String
  description String?
  icon        String? // emoji or icon name — "🍺", "🍽️", "💆"
  color       String   @default("bg-blue-500")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel    Hotel        @relation(fields: [hotelId], references: [id])
  products PosProduct[]

  @@unique([hotelId, name])
  @@index([hotelId])
}

model PosTerminal {
  id              String    @id @default(uuid())
  hotelId         String
  staffId         String?
  name            String
  location        String?
  terminalGroupId String?
  device          String
  status          String    @default("Online")
  setupCode       String?
  setupCodeExpiresAt DateTime?
  setupCodeQr     String?
  registeredDeviceKeyHash String?
  registeredDeviceName String?
  registeredIpAddress String?
  registeredAt    DateTime?
  currentStaffId  String?
  lastActivityAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  hotel         Hotel             @relation(fields: [hotelId], references: [id])
  staff         Staff?            @relation(fields: [staffId], references: [id])
  terminalGroup PosTerminalGroup? @relation(fields: [terminalGroupId], references: [id])
  currentStaff  Staff?            @relation("CurrentTerminalStaff", fields: [currentStaffId], references: [id])
  orders        PosOrder[]

  @@index([hotelId])
  @@index([staffId])
  @@index([terminalGroupId])
}

// ─── POS Terminal GROUPS ───────────────────────────────────────────────────────────────────

model PosTerminalGroup {
  id          String   @id @default(uuid())
  hotelId     String
  name        String // "Bar", "Outside Block A", "Rooftop", "Basement"
  level       Int // sort order — negative for basements (e.g. -1)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel        Hotel         @relation(fields: [hotelId], references: [id])
  posTerminals PosTerminal[]

  @@unique([hotelId, name])
  @@index([hotelId, level])
}

model PosTable {
  id        String   @id @default(uuid())
  hotelId   String
  name      String // "Table 1", "Bar Counter", "VIP Booth"
  section   String? // "Restaurant", "Bar", "Poolside", "Rooftop"
  capacity  Int? // number of seats
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel  Hotel      @relation(fields: [hotelId], references: [id])
  orders PosOrder[]

  @@unique([hotelId, name])
  @@index([hotelId])
  @@index([hotelId, section])
}

// ─── INVENTORY ────────────────────────────────────────────────────────────────

model InventoryItem {
  id          String   @id @default(uuid())
  hotelId     String
  name        String
  sku         String
  category    String
  description String?
  unit        String
  quantity    Decimal
  minStock    Decimal  @default(0)
  costPerUnit Decimal
  sellPrice   Decimal?
  supplier    String?
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel          Hotel               @relation(fields: [hotelId], references: [id])
  movements      StockMovement[]
  usedInProducts ProductIngredient[]

  @@unique([hotelId, sku])
  @@index([hotelId])
}

model StockMovement {
  id         String   @id @default(uuid())
  hotelId    String
  itemId     String
  type       String // IN, OUT, ADJUSTMENT, WASTAGE
  quantity   Decimal
  note       String?
  sourceType String? // POS_SALE, MANUAL, WASTAGE, PURCHASE, ADJUSTMENT
  sourceId   String? // orderId, requisitionId, etc.
  staffId    String? // who made the movement
  createdAt  DateTime @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id])

  @@index([hotelId])
}

// ─── HOUSEKEEPING ─────────────────────────────────────────────────────────────

model HousekeepingTask {
  id          String       @id @default(uuid())
  hotelId     String
  roomId      String
  assignedTo  String?
  type        String // CLEANING, TURNDOWN, MAINTENANCE, INSPECTION, AMENITY
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(NORMAL)
  notes       String?
  scheduledAt DateTime?
  dueBy       DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  hotel Hotel  @relation(fields: [hotelId], references: [id])
  room  Room   @relation(fields: [roomId], references: [id])
  staff Staff? @relation(fields: [assignedTo], references: [id])

  @@index([hotelId, status])
  @@index([hotelId, createdAt])
}

// ─── FACILITIES ───────────────────────────────────────────────────────────────

model FacilityType {
  id          String   @id @default(uuid())
  hotelId     String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel      Hotel      @relation(fields: [hotelId], references: [id])
  facilities Facility[]

  @@unique([hotelId, name])
  @@index([hotelId])
}

model FacilityLocation {
  id          String   @id @default(uuid())
  hotelId     String
  name        String
  building    String?
  floor       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel      Hotel      @relation(fields: [hotelId], references: [id])
  facilities Facility[]

  @@unique([hotelId, name])
  @@index([hotelId])
}

model FacilityDepartment {
  id          String   @id @default(uuid())
  hotelId     String
  name        String
  headId      String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel      Hotel      @relation(fields: [hotelId], references: [id])
  head       Staff?     @relation("FacilityDepartmentHead", fields: [headId], references: [id])
  facilities Facility[]

  @@unique([hotelId, name])
  @@index([hotelId])
}

model Facility {
  id                String         @id @default(uuid())
  hotelId           String
  name              String
  typeId            String?
  description       String?
  capacity          Int?
  status            FacilityStatus @default(ACTIVE)
  openTime          String?
  closeTime         String?
  operatingSchedule Json?
  baseRate          Decimal?
  rateUnit          String? // PER_HOUR, PER_SESSION, PER_DAY, FLAT
  requiresApproval  Boolean        @default(false)
  minDurationMins   Int?
  maxDurationMins   Int?
  images            String[]
  amenities         String[]
  locationId        String?
  departmentId      String?
  managerId         String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  hotel               Hotel                 @relation(fields: [hotelId], references: [id])
  type                FacilityType?         @relation(fields: [typeId], references: [id])
  location            FacilityLocation?     @relation(fields: [locationId], references: [id])
  department          FacilityDepartment?   @relation(fields: [departmentId], references: [id])
  manager             Staff?                @relation("FacilityManager", fields: [managerId], references: [id])
  bookings            FacilityBooking[]
  requisitions        FacilityRequisition[]
  maintenanceRequests MaintenanceRequest[]
  complaints          FacilityComplaint[]
  inspections         FacilityInspection[]

  @@index([hotelId])
  @@index([hotelId, typeId])
  @@index([hotelId, locationId])
  @@index([hotelId, departmentId])
  @@index([hotelId, managerId])
}

model FacilityBooking {
  id            String    @id @default(uuid())
  hotelId       String
  facilityId    String
  reservationId String?
  guestId       String?
  guestName     String
  roomNo        String?
  startTime     DateTime
  endTime       DateTime
  durationMins  Int
  status        String // PENDING, CONFIRMED, IN_PROGRESS, COMPLETED, CANCELLED, NO_SHOW
  pax           Int       @default(1)
  amount        Decimal
  chargeType    String // ROOM_CHARGE, DIRECT_PAYMENT, COMPLIMENTARY
  isPaid        Boolean   @default(false)
  invoiceId     String?
  approvedBy    String?
  approvedAt    DateTime?
  notes         String?
  cancelledAt   DateTime?
  cancelReason  String?
  refundMethod  String?
  creditNoteId  String?
  refundId      String?
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  hotel           Hotel        @relation(fields: [hotelId], references: [id])
  facility        Facility     @relation(fields: [facilityId], references: [id])
  reservation     Reservation? @relation(fields: [reservationId], references: [id])
  guest           Guest?       @relation(fields: [guestId], references: [id])
  invoice         Invoice?     @relation("FacilityBookingInvoice")
  approvedByStaff Staff?       @relation("FacilityBookingApprovedBy", fields: [approvedBy], references: [id])
  createdByStaff  Staff?       @relation("FacilityBookingCreatedBy", fields: [createdBy], references: [id])
  folioItems      FolioItem[]

  @@index([hotelId])
  @@index([hotelId, facilityId])
  @@index([hotelId, reservationId])
}

model FacilityRequisition {
  id              String    @id @default(uuid())
  hotelId         String
  facilityId      String
  requestedBy     String
  title           String
  description     String?
  priority        String // LOW, NORMAL, HIGH, URGENT
  status          String // PENDING, APPROVED, REJECTED, FULFILLED, CANCELLED
  items           Json
  estimatedTotal  Decimal?
  invoiceId       String?   
  approvedBy      String?
  approvedAt      DateTime?
  fulfilledAt     DateTime?
  rejectionReason String?
  inventoryLinked Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  hotel            Hotel    @relation(fields: [hotelId], references: [id])
  facility         Facility @relation(fields: [facilityId], references: [id])
  invoice          Invoice? @relation("FacilityRequisitionInvoice", fields: [invoiceId], references: [id])
  requestedByStaff Staff    @relation("FacilityRequisitionRequestedBy", fields: [requestedBy], references: [id])
  approvedByStaff  Staff?   @relation("FacilityRequisitionApprovedBy", fields: [approvedBy], references: [id])

  @@index([hotelId])
  @@index([hotelId, facilityId])
  @@index([hotelId, status])
  @@unique([invoiceId])
}

model MaintenanceRequest {
  id                       String    @id @default(uuid())
  hotelId                  String
  facilityId               String?
  roomId                   String?
  requestNo                String
  title                    String
  description              String
  category                 String // PLUMBING, ELECTRICAL, HVAC, FURNITURE, EQUIPMENT, STRUCTURAL, OTHER
  priority                 String // LOW, NORMAL, HIGH, URGENT
  status                   String // OPEN, ASSIGNED, IN_PROGRESS, PENDING_PARTS, RESOLVED, CLOSED
  reportedBy               String?
  assignedTo               String?
  assignedAt               DateTime?
  startedAt                DateTime?
  resolvedAt               DateTime?
  closedAt                 DateTime?
  estimatedMins            Int?
  actualMins               Int?
  partsUsed                Json?
  totalCost                Decimal?
  images                   String[]
  notes                    String?
  inspectionId             String?
  verificationInspectionId String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  hotel                  Hotel               @relation(fields: [hotelId], references: [id])
  facility               Facility?           @relation(fields: [facilityId], references: [id])
  room                   Room?               @relation(fields: [roomId], references: [id])
  reportedByStaff        Staff?              @relation("MaintenanceRequestReportedBy", fields: [reportedBy], references: [id])
  assignedToStaff        Staff?              @relation("MaintenanceRequestAssignedTo", fields: [assignedTo], references: [id])
  complaint              FacilityComplaint?  @relation("ComplaintMaintenance")
  inspection             FacilityInspection? @relation("InspectionFindings", fields: [inspectionId], references: [id])
  verificationInspection FacilityInspection? @relation("InspectionVerification", fields: [verificationInspectionId], references: [id])

  @@unique([hotelId, requestNo])
  @@index([hotelId])
  @@index([hotelId, status])
  @@index([hotelId, facilityId])
}

model FacilityComplaint {
  id                   String    @id @default(uuid())
  hotelId              String
  complaintNo          String
  reporterType         String // GUEST, STAFF
  reporterStaffId      String?
  reporterGuestId      String?
  channel              String // IN_PERSON, PHONE, EMAIL, WEB
  facilityId           String?
  roomId               String?
  title                String
  description          String
  category             String
  priority             String
  status               String // NEW, ACKNOWLEDGED, IN_PROGRESS, RESOLVED, CLOSED
  maintenanceRequestId String?   @unique
  createdAt            DateTime  @default(now())
  resolvedAt           DateTime?
  updatedAt            DateTime  @updatedAt

  hotel              Hotel               @relation(fields: [hotelId], references: [id])
  facility           Facility?           @relation(fields: [facilityId], references: [id])
  room               Room?               @relation(fields: [roomId], references: [id])
  reporterStaff      Staff?              @relation("FacilityComplaintReportedBy", fields: [reporterStaffId], references: [id])
  reporterGuest      Guest?              @relation(fields: [reporterGuestId], references: [id])
  maintenanceRequest MaintenanceRequest? @relation("ComplaintMaintenance", fields: [maintenanceRequestId], references: [id])

  @@unique([hotelId, complaintNo])
  @@index([hotelId])
  @@index([hotelId, status])
}

model FacilityInspection {
  id                    String   @id @default(uuid())
  hotelId               String
  inspectionNo          String
  inspectionType        String // INTERNAL, THIRD_PARTY, REGULATORY
  scheduledBy           String
  inspectorName         String?
  inspectorOrganization String?
  facilityId            String?
  area                  String?
  scheduledAt           DateTime
  checklist             Json?
  findings              String?
  score                 Int?
  status                String // SCHEDULED, IN_PROGRESS, SUBMITTED, CLOSED
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  hotel                Hotel                @relation(fields: [hotelId], references: [id])
  facility             Facility?            @relation(fields: [facilityId], references: [id])
  scheduledByStaff     Staff                @relation("FacilityInspectionScheduledBy", fields: [scheduledBy], references: [id])
  maintenanceRequests  MaintenanceRequest[] @relation("InspectionFindings")
  verificationRequests MaintenanceRequest[] @relation("InspectionVerification")

  @@unique([hotelId, inspectionNo])
  @@index([hotelId])
  @@index([hotelId, status])
}

// ─── LEDGER / CHART OF ACCOUNTS ──────────────────────────────────────────────

// Account types:
//   ASSET       — things the hotel owns (cash, AR, inventory)
//   LIABILITY   — things the hotel owes (deposits, payables)
//   EQUITY      — owner's equity
//   REVENUE     — income earned
//   EXPENSE     — costs incurred (COGS, salaries, supplies)

model Account {
  id            String   @id @default(uuid())
  hotelId       String
  code          String // e.g. "1000", "4100"
  name          String // e.g. "Cash", "Room Revenue"
  type          String // ASSET | LIABILITY | EQUITY | REVENUE | EXPENSE
  normalBalance String // DEBIT | CREDIT (which side increases the account)
  description   String?
  isActive      Boolean  @default(true)
  isSystem      Boolean  @default(false) // system accounts cannot be deleted
  parentCode    String? // for sub-accounts e.g. 4100 under 4000
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  hotel        Hotel         @relation(fields: [hotelId], references: [id])
  journalLines JournalLine[] @relation("AccountJournalLines")
  debitLines   JournalLine[] @relation("DebitAccount")
  creditLines  JournalLine[] @relation("CreditAccount")

  @@unique([hotelId, code])
  @@index([hotelId])
  @@index([hotelId, type])
}

model JournalEntry {
  id          String   @id @default(uuid())
  hotelId     String
  entryNo     String   @unique // JE-2026-0001
  date        DateTime @default(now())
  description String
  reference   String? // invoice no, order no, payment ref etc
  sourceType  String? // RESERVATION | POS_SALE | PAYMENT | FOLIO | MANUAL | PAYROLL
  sourceId    String? // FK to the source record
  postedBy    String? // staffId who posted (null = system auto-post)
  isReversed  Boolean  @default(false)
  reversedBy  String? // JournalEntry.id of the reversal entry
  createdAt   DateTime @default(now())

  hotel Hotel         @relation(fields: [hotelId], references: [id])
  lines JournalLine[]

  @@index([hotelId])
  @@index([hotelId, date])
  @@index([hotelId, sourceType, sourceId])
}

model JournalLine {
  id              String  @id @default(uuid())
  journalEntryId  String
  accountId       String
  debitAccountId  String? // redundant FK for fast querying by account
  creditAccountId String? // redundant FK for fast querying by account
  type            String // DEBIT | CREDIT
  amount          Decimal
  description     String?

  journalEntry  JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account       Account      @relation("AccountJournalLines", fields: [accountId], references: [id])
  debitAccount  Account?     @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccount Account?     @relation("CreditAccount", fields: [creditAccountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}
