generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  RECEPTIONIST
  HOUSEKEEPING
  CASHIER
  BARTENDER
  STAFF
}

enum PermissionChangeTarget {
  ROLE
  USER
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  DIRTY
  MAINTENANCE
  OUT_OF_ORDER
  RESERVED
  HOUSEKEEPING
}

enum RoomType {
  STANDARD
  DELUXE
  SUITE
  EXECUTIVE
  PRESIDENTIAL
  PENTHOUSE
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum AttendanceType {
  CLOCK_IN
  CLOCK_OUT
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  SKIPPED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  ANNUAL
  SICK
  EMERGENCY
  UNPAID
  MATERNITY
  PATERNITY
}

enum GuestRole {
  PRIMARY    // the person who made the booking
  ADDITIONAL // other adult guests
  CHILD      // minors, no ID required
}

enum BookingType {
  INDIVIDUAL // 1 or 2 guests, single room
  FAMILY     // adults + children, single room
  COMPANY    // billed to a company account
  GROUP      // multiple rooms under one booking
}


// ─── HOTEL ────────────────────────────────────────────────────────────────────

model Hotel {
  id        String   @id @default(uuid())
  name      String
  domain    String?  @unique
  address   String
  city      String
  state     String?
  country   String
  phone     String
  phoneNormalized  String?
  email     String
  website   String?
  description String?
  logo      String?
  currency  String   @default("NGN")
  timezone  String   @default("Africa/Lagos")
  taxRate      Decimal? @default(0)
  latitude     Float?
  longitude    Float?
  geofenceEnabled Boolean @default(false)
  geofenceRadiusMeters Int @default(150)
  attendancePinRequired Boolean @default(false)
  attendanceKioskEnabled Boolean @default(true)
  attendancePersonalEnabled Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  floors           Floor[]
  rooms            Room[]
  staff            Staff[]
  guests           Guest[]
  reservations     Reservation[]
  facilities       Facility[]
  posOrders        PosOrder[]
  posProducts      PosProduct[]
  posTerminals     PosTerminal[]
  posTerminalGroups     PosTerminalGroup[]
  posTables        PosTable[]
  inventoryItems   InventoryItem[]
  housekeepingTasks HousekeepingTask[]
  companies     Company[]
  groupBookings GroupBooking[]
  departments   Department[]
  inventoryCategories InventoryCategory[]
  posProductCategories PosProductCategory[]
  suppliers    Supplier[]
  shiftTemplates ShiftTemplate[]
  roomTypeConfigs RoomTypeConfig[]
  rolePermissions RolePermission[]
  permissionAuditLogs PermissionAuditLog[]
  accounts      Account[]
  journalEntries JournalEntry[]
  auditLogs     AuditLog[]
  notificationPreferences NotificationPreference[]
}

// ─── USERS & AUTH ─────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  username     String?
  passwordHash String
  role         Role      @default(STAFF)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  mustChangePassword Boolean   @default(false)

  // Granular permission overrides on top of role defaults
  permissionGrants String[] @default([])
  permissionDenies String[] @default([])

  staff         Staff?
  refreshTokens RefreshToken[]
  permissionAuditActor PermissionAuditLog[] @relation("PermissionAuditActor")
  permissionAuditTarget PermissionAuditLog[] @relation("PermissionAuditTarget")
  auditLogsActor AuditLog[] @relation("AuditActor")
  auditLogsTarget AuditLog[] @relation("AuditTarget")
  notificationPreferences NotificationPreference[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  impersonatorId String?
  isImpersonation Boolean @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id           String   @id @default(uuid())
  hotelId      String
  actorUserId  String
  action       String
  targetType   String?
  targetId     String?
  targetUserId String?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  hotel     Hotel @relation(fields: [hotelId], references: [id])
  actor     User  @relation("AuditActor", fields: [actorUserId], references: [id])
  targetUser User? @relation("AuditTarget", fields: [targetUserId], references: [id])

  @@index([hotelId])
  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action])
}

model NotificationPreference {
  id           String   @id @default(uuid())
  userId       String
  hotelId      String
  event        String
  channelEmail Boolean  @default(true)
  channelInApp Boolean  @default(true)
  channelPush  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([userId, event])
  @@index([hotelId])
}

model RolePermission {
  id          String   @id @default(uuid())
  hotelId     String
  role        Role
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@unique([hotelId, role])
  @@index([hotelId])
}

model PermissionAuditLog {
  id           String   @id @default(uuid())
  hotelId      String
  actorUserId  String
  targetUserId String?
  targetRole   Role?
  targetType   PermissionChangeTarget
  before       String[] @default([])
  after        String[] @default([])
  reason       String?
  createdAt    DateTime @default(now())

  hotel      Hotel @relation(fields: [hotelId], references: [id])
  actor      User  @relation("PermissionAuditActor", fields: [actorUserId], references: [id])
  targetUser User? @relation("PermissionAuditTarget", fields: [targetUserId], references: [id])

  @@index([hotelId])
  @@index([actorUserId])
  @@index([targetUserId])
}

// ─── STAFF ────────────────────────────────────────────────────────────────────

model Staff {
  id           String   @id @default(uuid())
  userId       String   @unique
  hotelId      String
  employeeCode String   @unique
  firstName    String
  lastName     String
  phone        String?
  phoneNormalized  String?
  avatar       String?
  department   String
  position     String
  salary       Decimal  @default(0)
  hireDate     DateTime
  pinHash      String?
  pinUpdatedAt DateTime?
  pinLastUsedAt DateTime?
  pinFailedAttempts Int @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User               @relation(fields: [userId], references: [id])
  hotel      Hotel              @relation(fields: [hotelId], references: [id])
  operatingTerminals PosTerminal[] @relation("CurrentTerminalStaff")
  attendance Attendance[]
  leaves     Leave[]
  tasks      HousekeepingTask[]
  posTerminals PosTerminal[]
  posOrders PosOrder[]
}

model Attendance {
  id        String         @id @default(uuid())
  staffId   String
  hotelId   String
  type      AttendanceType
  timestamp DateTime       @default(now())
  method    String         @default("PIN") // PIN, QR, BIOMETRIC
  note      String?
  latitude  Float?
  longitude Float?

  staff Staff @relation(fields: [staffId], references: [id])

  @@index([hotelId])
  @@index([staffId, timestamp])
}

model Leave {
  id        String      @id @default(uuid())
  staffId   String
  hotelId   String
  type      LeaveType
  startDate DateTime
  endDate   DateTime
  reason    String
  status    LeaveStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  staff Staff @relation(fields: [staffId], references: [id])

  @@index([hotelId])
}

// ─── DEPARTMENTS ─────────────────────────────────────────────────────────────

model Department {
  id          String   @id @default(uuid())
  hotelId     String
  name        String
  description String?
  color       String   @default("bg-blue-500")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@unique([hotelId, name])
  @@index([hotelId])
}

// ─── INVENTORY CATEGORIES ────────────────────────────────────────────────────

model InventoryCategory {
  id          String   @id @default(uuid())
  hotelId     String
  name        String
  description String?
  color       String   @default("bg-blue-500")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@unique([hotelId, name])
  @@index([hotelId])
}

// ─── SUPPLIERS ──────────────────────────────────────────────────────────────

model Supplier {
  id          String   @id @default(uuid())
  hotelId     String
  name        String
  contact     String?
  phone       String?
  email       String?
  address     String?
  notes       String?
  categories  String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@unique([hotelId, name])
  @@index([hotelId])
}

// ─── SHIFT TEMPLATES ────────────────────────────────────────────────────────

model ShiftTemplate {
  id        String   @id @default(uuid())
  hotelId   String
  name      String
  startTime String
  endTime   String
  days      String[] @default([])
  color     String   @default("bg-blue-500")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@unique([hotelId, name])
  @@index([hotelId])
}

// ─── ROOM TYPE CONFIGS ──────────────────────────────────────────────────────

model RoomTypeConfig {
  id          String   @id @default(uuid())
  hotelId     String
  name        String
  description String?
  baseRate    Decimal  @default(0)
  capacity    Int      @default(1)
  beds        String   @default("1 Queen")
  amenities   String[] @default([])
  color       String   @default("bg-blue-500")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@unique([hotelId, name])
  @@index([hotelId])
}

// ─── FLOORS ───────────────────────────────────────────────────────────────────

model Floor {
  id          String   @id @default(uuid())
  hotelId     String
  name        String   // "Ground Floor", "Outside Block A", "Rooftop", "Basement"
  level       Int      // sort order — negative for basements (e.g. -1)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel Hotel  @relation(fields: [hotelId], references: [id])
  rooms Room[]

  @@unique([hotelId, name])
  @@unique([hotelId, level])
  @@index([hotelId])
}


// ─── ROOMS ────────────────────────────────────────────────────────────────────

model Room {
  id          String     @id @default(uuid())
  hotelId     String
  number      String
  floorId     String?
  type        RoomType
  status      RoomStatus @default(AVAILABLE)
  baseRate    Decimal
  maxGuests   Int        @default(2)
  description String?
  amenities   String[]
  images      String[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  hotel             Hotel              @relation(fields: [hotelId], references: [id])
  floor             Floor?             @relation(fields: [floorId], references: [id])
  reservations      Reservation[]
  housekeepingTasks HousekeepingTask[]

  @@unique([hotelId, number])
  @@index([hotelId, status])
  @@index([hotelId, floorId])
}

// ─── COMPANIES ────────────────────────────────────────────────────────────────

model Company {
  id          String   @id @default(uuid())
  hotelId     String
  name        String
  email       String?
  phone       String?
  phoneNormalized  String?
  address     String?
  taxId       String?  // for invoicing
  contactName String?  // primary billing contact
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel        Hotel         @relation(fields: [hotelId], references: [id])
  reservations Reservation[]

  @@unique([hotelId, name])
  @@index([hotelId])
}

// ─── GROUP BOOKINGS ───────────────────────────────────────────────────────────

model GroupBooking {
  id        String   @id @default(uuid())
  hotelId   String
  groupNo   String   @unique  // GRP-2026-001
  name      String            // "Dangote Wedding Party", "NNPC Conference"
  companyId String?           // optional — who is paying
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel        Hotel         @relation(fields: [hotelId], references: [id])
  reservations Reservation[]

  @@index([hotelId])
}


// ─── GUESTS ───────────────────────────────────────────────────────────────────

model Guest {
  id          String    @id @default(uuid())
  hotelId     String
  firstName   String
  lastName    String
  email       String?
  phone       String
  phoneNormalized  String?

  nationality String?
  idType      String?   // PASSPORT, NATIONAL_ID, DRIVERS_LICENSE
  idNumber    String?
  dateOfBirth DateTime?
  address     String?
  notes       String?
  stayType String?   // FULL_TIME, SHORT_TIME
  isVip       Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  hotel              Hotel              @relation(fields: [hotelId], references: [id])
  reservations       Reservation[]      // reservations where this guest is primary
  reservationGuests  ReservationGuest[] // all reservations this guest appears on

  @@index([hotelId])
  @@index([hotelId, email])
}

// ─── RESERVATIONS ─────────────────────────────────────────────────────────────

model Reservation {
  id              String            @id @default(uuid())
  hotelId         String
  guestId         String            // primary guest — quick FK for display
  roomId          String
  companyId       String?           // set if this is a company booking
  groupBookingId  String?           // set if part of a group
  reservationNo   String            @unique
  bookingType     BookingType       @default(INDIVIDUAL)
  checkIn         DateTime
  checkOut        DateTime
  adults          Int               @default(1)
  children        Int               @default(0)
  status          ReservationStatus @default(PENDING)
  paymentStatus   PaymentStatus     @default(UNPAID)
  totalAmount     Decimal
  paidAmount      Decimal           @default(0)
  source          String            @default("DIRECT")
  specialRequests String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  hotel        Hotel              @relation(fields: [hotelId], references: [id])
  guest        Guest              @relation(fields: [guestId], references: [id])
  room         Room               @relation(fields: [roomId], references: [id])
  company      Company?           @relation(fields: [companyId], references: [id])
  groupBooking GroupBooking?      @relation(fields: [groupBookingId], references: [id])
  guests       ReservationGuest[] // full guest list including primary
  invoices     Invoice[]
  folioItems   FolioItem[]
  posOrders    PosOrder[]

  @@index([hotelId, status])
  @@index([hotelId, checkIn, checkOut])
  @@index([hotelId, companyId])
  @@index([hotelId, groupBookingId])
}

// ─── RESERVATION GUESTS (many guests per reservation) ─────────────────────────

model ReservationGuest {
  id            String    @id @default(uuid())
  reservationId String
  guestId       String
  role          GuestRole @default(ADDITIONAL)
  addedAt       DateTime  @default(now()) // audit — when was this guest added/changed

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  guest       Guest       @relation(fields: [guestId], references: [id])

  @@unique([reservationId, guestId]) // a guest can only appear once per reservation
  @@index([reservationId])
  @@index([guestId])
}

// ─── FINANCE ──────────────────────────────────────────────────────────────────

model Invoice {
  id            String        @id @default(uuid())
  hotelId       String
  reservationId String?       // null for walk-in / POS-only invoices
  posOrderId    String?
  invoiceNo     String        @unique
  issuedAt      DateTime      @default(now())
  dueAt         DateTime?
  subtotal      Decimal
  tax           Decimal
  discount      Decimal       @default(0)
  total         Decimal
  type          String        @default("RESERVATION") // RESERVATION | POS | FACILITY | MANUAL
  paymentStatus PaymentStatus @default(UNPAID)
  notes         String?

  reservation Reservation? @relation(fields: [reservationId], references: [id])
  posOrder    PosOrder?    @relation(fields: [posOrderId], references: [id])
  payments    Payment[]

  @@index([hotelId])
  @@index([hotelId, paymentStatus])
}

model Payment {
  id        String   @id @default(uuid())
  hotelId   String
  invoiceId String
  amount    Decimal
  method    String   // CASH, CARD, BANK_TRANSFER, MOBILE_MONEY, ROOM_CHARGE
  reference String?
  paidAt    DateTime @default(now())
  note      String?

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([hotelId])
}

model FolioItem {
  id            String   @id @default(uuid())
  hotelId       String
  reservationId String
  description   String
  amount        Decimal
  quantity      Int      @default(1)
  category      String   // ROOM, FOOD, LAUNDRY, SPA, MISC
  posOrderId    String?  // which POS order generated this charge
  createdAt     DateTime @default(now())

  reservation Reservation @relation(fields: [reservationId], references: [id])

  @@index([hotelId])
}

// ─── POS / STORE ──────────────────────────────────────────────────────────────

model PosOrder {
  id            String      @id @default(uuid())
  hotelId       String
  orderNo       String      @unique
  tableId         String?   // FK to PosTable
  tableNo       String?
  roomNo          String?
  reservationId   String?   // FK for room charge flow
  staffId         String?
  posTerminalId   String?
  type          String      // DINE_IN, ROOM_SERVICE, TAKEAWAY, RETAIL
  status        OrderStatus @default(PENDING)
  subtotal      Decimal
  tax           Decimal
  discount      Decimal     @default(0)
  total         Decimal
  paymentMethod String?
  isPaid        Boolean     @default(false)
  note          String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  hotel    Hotel          @relation(fields: [hotelId], references: [id])
  posTerminal    PosTerminal?       @relation(fields: [posTerminalId], references: [id])
  table       PosTable?     @relation(fields: [tableId],       references: [id])
  reservation Reservation?  @relation(fields: [reservationId], references: [id])
  staff       Staff?        @relation(fields: [staffId],       references: [id])
  
  items    PosOrderItem[]
  invoices Invoice[]

  @@index([hotelId])
  @@index([hotelId, createdAt])
}

model ProductIngredient {
  id              String   @id @default(uuid())
  hotelId         String
  productId       String
  inventoryItemId String
  quantity        Decimal  // amount of inventory item consumed per 1 unit sold
  unit            String?  // display unit override (e.g. "ml", "g")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product       PosProduct    @relation(fields: [productId],       references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@unique([productId, inventoryItemId])
  @@index([hotelId])
  @@index([productId])
}

model PosOrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  name      String   // snapshot at time of sale
  price     Decimal  // snapshot at time of sale
  quantity  Int
  total     Decimal
  note      String?

  order   PosOrder   @relation(fields: [orderId], references: [id])
  product PosProduct @relation(fields: [productId], references: [id])
}

model PosProduct {
  id          String   @id @default(uuid())
  hotelId     String
  name        String
  sku         String?
  description String?
  price       Decimal
  categoryId  String
  unit        String   @default("item")
  image       String?
  type        String   @default("PHYSICAL") // PHYSICAL | SERVICE | BUNDLE
  isAvailable Boolean  @default(true)
  stock       Int?     // null = unlimited (e.g. services)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel       Hotel               @relation(fields: [hotelId], references: [id])
  orderItems  PosOrderItem[]
  ingredients ProductIngredient[]
  category    PosProductCategory @relation(fields: [categoryId], references: [id])

  @@index([hotelId])
  @@unique([hotelId, sku])
}

model PosProductCategory {
  id          String   @id @default(uuid())
  hotelId     String
  name        String
  description String?
  icon        String?   // emoji or icon name — "🍺", "🍽️", "💆"
  color       String   @default("bg-blue-500")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel    Hotel        @relation(fields: [hotelId], references: [id])
  products PosProduct[]

  @@unique([hotelId, name])
  @@index([hotelId])
}

model PosTerminal {
  id        String   @id @default(uuid())
  hotelId   String
  staffId   String?
  name      String
  location  String?
  terminalGroupId     String?
  device    String
  status    String   @default("Online")
  setupCode      String?
  setupCodeQr String?
  currentStaffId String?
  lastActivityAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id])
  staff Staff? @relation(fields: [staffId], references: [id])
  terminalGroup PosTerminalGroup? @relation(fields: [terminalGroupId], references: [id])
  currentStaff Staff? @relation("CurrentTerminalStaff", fields: [currentStaffId], references: [id])
  orders    PosOrder[]

  @@index([hotelId])
  @@index([staffId])
  @@index([terminalGroupId])
}

// ─── POS Terminal GROUPS ───────────────────────────────────────────────────────────────────

model PosTerminalGroup {
  id          String   @id @default(uuid())
  hotelId     String
  name        String   // "Bar", "Outside Block A", "Rooftop", "Basement"
  level       Int      // sort order — negative for basements (e.g. -1)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel Hotel  @relation(fields: [hotelId], references: [id])
  posTerminals PosTerminal[]

  @@unique([hotelId, name])
  @@index([hotelId, level])
}

model PosTable {
  id          String   @id @default(uuid())
  hotelId     String
  name        String   // "Table 1", "Bar Counter", "VIP Booth"
  section     String?  // "Restaurant", "Bar", "Poolside", "Rooftop"
  capacity    Int?     // number of seats
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel  Hotel      @relation(fields: [hotelId], references: [id])
  orders PosOrder[]

  @@unique([hotelId, name])
  @@index([hotelId])
  @@index([hotelId, section])
}

// ─── INVENTORY ────────────────────────────────────────────────────────────────

model InventoryItem {
  id          String   @id @default(uuid())
  hotelId     String
  name        String
  sku         String
  category    String
  description String?
  unit        String
  quantity    Decimal
  minStock    Decimal  @default(0)
  costPerUnit Decimal
  sellPrice   Decimal?
  supplier    String?
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel       Hotel               @relation(fields: [hotelId], references: [id])
  movements   StockMovement[]
  usedInProducts ProductIngredient[]

  @@unique([hotelId, sku])
  @@index([hotelId])
}

model StockMovement {
  id        String   @id @default(uuid())
  hotelId   String
  itemId    String
  type       String   // IN, OUT, ADJUSTMENT, WASTAGE
  quantity   Decimal
  note       String?
  sourceType String?  // POS_SALE, MANUAL, WASTAGE, PURCHASE, ADJUSTMENT
  sourceId   String?  // orderId, requisitionId, etc.
  staffId    String?  // who made the movement
  createdAt  DateTime @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id])

  @@index([hotelId])
}

// ─── HOUSEKEEPING ─────────────────────────────────────────────────────────────

model HousekeepingTask {
  id          String       @id @default(uuid())
  hotelId     String
  roomId      String
  assignedTo  String?
  type        String       // CLEANING, TURNDOWN, MAINTENANCE, INSPECTION, AMENITY
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(NORMAL)
  notes       String?
  scheduledAt DateTime?
  dueBy       DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  hotel Hotel  @relation(fields: [hotelId], references: [id])
  room  Room   @relation(fields: [roomId], references: [id])
  staff Staff? @relation(fields: [assignedTo], references: [id])

  @@index([hotelId, status])
  @@index([hotelId, createdAt])
}

// ─── FACILITIES ───────────────────────────────────────────────────────────────

model Facility {
  id          String   @id @default(uuid())
  hotelId     String
  name        String
  type        String   // POOL, GYM, SPA, CONFERENCE, RESTAURANT
  description String?
  capacity    Int?
  isActive    Boolean  @default(true)
  openTime    String?
  closeTime   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hotel    Hotel             @relation(fields: [hotelId], references: [id])
  bookings FacilityBooking[]

  @@index([hotelId])
}

model FacilityBooking {
  id         String   @id @default(uuid())
  hotelId    String
  facilityId String
  guestName  String
  roomNo     String?
  startTime  DateTime
  endTime    DateTime
  notes      String?
  createdAt  DateTime @default(now())

  facility Facility @relation(fields: [facilityId], references: [id])

  @@index([hotelId])
}


// ─── LEDGER / CHART OF ACCOUNTS ──────────────────────────────────────────────

// Account types:
//   ASSET       — things the hotel owns (cash, AR, inventory)
//   LIABILITY   — things the hotel owes (deposits, payables)
//   EQUITY      — owner's equity
//   REVENUE     — income earned
//   EXPENSE     — costs incurred (COGS, salaries, supplies)

model Account {
  id            String   @id @default(uuid())
  hotelId       String
  code          String   // e.g. "1000", "4100"
  name          String   // e.g. "Cash", "Room Revenue"
  type          String   // ASSET | LIABILITY | EQUITY | REVENUE | EXPENSE
  normalBalance String   // DEBIT | CREDIT (which side increases the account)
  description   String?
  isActive      Boolean  @default(true)
  isSystem      Boolean  @default(false) // system accounts cannot be deleted
  parentCode    String?  // for sub-accounts e.g. 4100 under 4000
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  hotel        Hotel          @relation(fields: [hotelId], references: [id])
  journalLines  JournalLine[] @relation("AccountJournalLines")
  debitLines   JournalLine[]  @relation("DebitAccount")
  creditLines  JournalLine[]  @relation("CreditAccount")

  @@unique([hotelId, code])
  @@index([hotelId])
  @@index([hotelId, type])
}

model JournalEntry {
  id          String   @id @default(uuid())
  hotelId     String
  entryNo     String   @unique  // JE-2026-0001
  date        DateTime @default(now())
  description String
  reference   String?  // invoice no, order no, payment ref etc
  sourceType  String?  // RESERVATION | POS_SALE | PAYMENT | FOLIO | MANUAL | PAYROLL
  sourceId    String?  // FK to the source record
  postedBy    String?  // staffId who posted (null = system auto-post)
  isReversed  Boolean  @default(false)
  reversedBy  String?  // JournalEntry.id of the reversal entry
  createdAt   DateTime @default(now())

  hotel Hotel         @relation(fields: [hotelId], references: [id])
  lines JournalLine[]

  @@index([hotelId])
  @@index([hotelId, date])
  @@index([hotelId, sourceType, sourceId])
}

model JournalLine {
  id             String   @id @default(uuid())
  journalEntryId String
  accountId      String
  debitAccountId  String?  // redundant FK for fast querying by account
  creditAccountId String?  // redundant FK for fast querying by account
  type           String   // DEBIT | CREDIT
  amount         Decimal
  description    String?

  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        Account      @relation("AccountJournalLines", fields: [accountId],       references: [id])
  debitAccount   Account?     @relation("DebitAccount",  fields: [debitAccountId],  references: [id])
  creditAccount  Account?     @relation("CreditAccount", fields: [creditAccountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}
